# Copy to .env and fill in. .env is gitignored — keys never leave your machine.
# For GitHub Actions, set these as repo secrets:
#   github.com/quinnstone/minihedgefund/settings/secrets/actions

# ─── Anthropic (the brain) ──────────────────────────────────
# Required. Agents will not run without this.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Discord delivery ───────────────────────────────────────
# Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ─── Market & macro data ────────────────────────────────────
# NewsAPI — 100 req/day free tier is sufficient
# https://newsapi.org
NEWS_API_KEY=

# FRED — free, instant signup
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Reddit ─────────────────────────────────────────────────
# Default uses Reddit's RSS endpoint with fallback to unauth JSON.
# No creds needed — RSS works in CI where the JSON path is IP-blocked.
REDDIT_USER_AGENT=MiniHedgeFund/1.0 (by /u/quinnstone)

# ─── StockTwits (LOCAL RUNS ONLY) ───────────────────────────
# StockTwits 403s from GitHub Actions IPs. Set to "true" in your local
# .env to use it in dev. Leave unset in CI — the sentiment scout falls
# back to Reddit + news polarity gracefully.
# STOCKTWITS_ENABLED=true
