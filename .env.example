# Copy to .env and fill in. .env is gitignored — keys never leave your machine.
# For GitHub Actions, set these as repo secrets:
#   github.com/quinnstone/minihedgefund/settings/secrets/actions

# ─── Anthropic (the brain) ──────────────────────────────────
# Required. Agents will not run without this.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Discord delivery ───────────────────────────────────────
# Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ─── Market & macro data ────────────────────────────────────
# NewsAPI — 100 req/day free tier is sufficient
# https://newsapi.org
NEWS_API_KEY=

# FRED — free, instant signup
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Reddit ─────────────────────────────────────────────────
# Default path uses Reddit's unauth JSON endpoints (no creds needed).
# Only fill these in if you want authenticated PRAW access for higher
# rate limits. The unauth path covers our weekly volume comfortably.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MiniHedgeFund/1.0 (by /u/quinnstone)
